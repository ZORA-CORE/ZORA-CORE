# ZORA CORE Environment Variables
# Copy this file to .env.local and fill in your API keys

# NASA API Key (from https://api.nasa.gov/)
# Used for NASA POWER API and other NASA endpoints
NASA_API_KEY=your_nasa_api_key_here

# Copernicus Climate Data Store API Key (from https://cds.climate.copernicus.eu/)
# Used for authenticated access to Copernicus satellite data
COPERNICUS_API_KEY=your_copernicus_api_key_here

# Vercel KV (Redis) - for EIVOR hot memory
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Pinecone - for EIVOR semantic memory
PINECONE_API_KEY=
PINECONE_INDEX=eivor-memory

# GitHub - for Bifrost atomic commits
GITHUB_TOKEN=

# Vercel - for THOR deployments
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Dify.ai - for the Zoracore chat interface (/chat)
# Get your API key from https://dify.ai/ > Your App > API Access
# This is a SERVER-ONLY secret. Do NOT prefix with NEXT_PUBLIC_.
DIFY_API_KEY=
# Optional override. Defaults to https://api.dify.ai/v1
DIFY_API_BASE_URL=

# -----------------------------------------------------------------------
# Valhalla AI — Infinity Engine (native Claude orchestrator)
# -----------------------------------------------------------------------
# Set to "1" or "true" to enable the `/api/swarm` sovereign orchestrator.
# When disabled, the endpoint returns 503 and the existing Dify proxy
# continues to serve all chat traffic. This is intentional: the native
# swarm lands in parallel to Dify and gets wired into the UI behind a
# feature toggle in a later PR.
VALHALLA_NATIVE_SWARM=

# Client-side mirror of VALHALLA_NATIVE_SWARM. Set to "1" to make the
# chat UI route new turns to /api/swarm instead of /api/chat (Dify).
# Independent of the server flag: if the client flag is on but the
# server flag is off, /api/swarm 503s and the UI silently falls back
# to the Dify proxy — so flipping this on Vercel is safe even before
# VALHALLA_NATIVE_SWARM is enabled.
NEXT_PUBLIC_VALHALLA_NATIVE_SWARM=

# Anthropic API key — https://console.anthropic.com/settings/keys
# Required when VALHALLA_NATIVE_SWARM is enabled. The native swarm
# uses Claude exclusively; there is no OpenAI fallback.
ANTHROPIC_API_KEY=

# Voyage AI embeddings key — https://dash.voyageai.com/api-keys
# Powers the EIVOR episodic memory (Voyage `voyage-3`, 1024 dims). When
# this key is absent the orchestrator runs without recall — the loop
# still executes but EIVOR sees an empty `## Recalled memories` block.
VOYAGE_API_KEY=

# Supabase project for the `valhalla_memories` pgvector table. The
# schema lives in supabase/migrations/002_valhalla_memories.sql — apply
# it once per environment. The service-role key stays server-side only;
# never prefix with NEXT_PUBLIC_. Memory writes/reads are gated on
# both variables being set; missing either one silently disables recall
# and persistence (the orchestrator still runs end-to-end).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub PAT for Valkyrie 2.0 auto-repo creation (PR 3). Fine-grained,
# scoped to the ZORA-CORE org with Administration: write, Contents:
# write, Workflows: write, Metadata: read.
GITHUB_VALHALLA_PAT=
